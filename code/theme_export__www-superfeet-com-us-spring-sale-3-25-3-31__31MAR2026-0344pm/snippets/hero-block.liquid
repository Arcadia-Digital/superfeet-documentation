{%- comment -%}
  Snippet: hero-block.liquid
  Purpose: reusable hero block (1-up / 2-up / 3-up sections)
  Usage: {% render 'hero-block', block: block %}
{%- endcomment -%}

{%- assign block_id = block.id | default: 'hero-block' -%}
{{ 'component-modal-video.css' | asset_url | stylesheet_tag }}

{%- comment -%} Variables {%- endcomment -%}
{%- assign disclaimer_exists = false -%}
{%- assign desktop_content_position = block.settings.desktop_content_position | default: 'middle-center' -%}
{%- assign mobile_content_position = block.settings.mobile_content_position | default: 'middle' -%}
{%- assign border_radius_desktop = border_radius_desktop | default: 0 -%}
{%- assign border_radius_mobile = border_radius_mobile | default: 0 -%}
{%- assign mobile_max_height = block.settings.mobile_max_height | default: 0 -%}
{%- assign background_opacity = block.settings.content_background_opacity | divided_by: 100.00 -%}

{%- comment -%} Normalize content position classes {%- endcomment -%}
{%- case desktop_content_position -%}
  {%- when 'top' -%}{%- assign desktop_content_position = 'top-center' -%}
  {%- when 'middle' -%}{%- assign desktop_content_position = 'middle-center' -%}
  {%- when 'bottom' -%}{%- assign desktop_content_position = 'bottom-center' -%}
{%- endcase -%}
{%- case mobile_content_position -%}
  {%- when 'top' -%}{%- assign mobile_content_position = 'top-center' -%}
  {%- when 'middle' -%}{%- assign mobile_content_position = 'middle-center' -%}
  {%- when 'bottom' -%}{%- assign mobile_content_position = 'bottom-center' -%}
{%- endcase -%}

{%- comment -%} Check for media - separately for desktop and mobile {%- endcomment -%}
{%- assign has_desktop_image = false -%}
{%- if block.settings.desktop_large_image != blank or block.settings.desktop_image != blank -%}
  {%- assign has_desktop_image = true -%}
{%- endif -%}
{%- assign has_mobile_image = false -%}
{%- if block.settings.mobile_image != blank -%}
  {%- assign has_mobile_image = true -%}
{%- endif -%}
{%- assign has_images = false -%}
{%- if has_desktop_image or has_mobile_image -%}
  {%- assign has_images = true -%}
{%- endif -%}

{%- assign has_desktop_video = false -%}
{%- if block.settings.desktop_large_video != blank or block.settings.desktop_video != blank -%}
  {%- assign has_desktop_video = true -%}
{%- endif -%}
{%- assign has_mobile_video = false -%}
{%- if block.settings.mobile_video != blank -%}
  {%- assign has_mobile_video = true -%}
{%- endif -%}
{%- assign has_videos = false -%}
{%- if has_desktop_video or has_mobile_video -%}
  {%- assign has_videos = true -%}
{%- endif -%}

{%- comment -%} Check if hover video should be enabled (only where both image and video exist for that breakpoint) {%- endcomment -%}
{%- assign has_desktop_hover = false -%}
{%- if has_desktop_image and has_desktop_video and block.settings.use_video == false and block.settings.enable_hover_video == true -%}
  {%- assign has_desktop_hover = true -%}
{%- endif -%}
{%- assign has_mobile_hover = false -%}
{%- if has_mobile_image and has_mobile_video and block.settings.use_video == false and block.settings.enable_hover_video == true -%}
  {%- assign has_mobile_hover = true -%}
{%- endif -%}
{%- assign has_both_media = false -%}
{%- if has_desktop_hover or has_mobile_hover -%}
  {%- assign has_both_media = true -%}
{%- endif -%}

{%- comment -%} Preload images {%- endcomment -%}
{%- if block.settings.no_lazy_load -%}
  {%- if block.settings.desktop_large_image != blank -%}
    <link rel="preload" href="{{ block.settings.desktop_large_image | image_url }}" as="image" fetchpriority="high" />
  {%- endif -%}
  {%- if block.settings.desktop_image != blank -%}
    <link rel="preload" href="{{ block.settings.desktop_image | image_url }}" as="image" fetchpriority="high" />
  {%- endif -%}
  {%- if block.settings.mobile_image != blank -%}
    <link rel="preload" href="{{ block.settings.mobile_image | image_url }}" as="image" fetchpriority="high" />
  {%- endif -%}
{%- endif -%}

<div id="hero-block-{{ block_id }}"
     class="hero-banner-block-inner 
            banner--content-align-{{ block.settings.desktop_content_alignment }}
            banner--content-align-mobile-{{ block.settings.mobile_content_alignment }}
            {% if block.settings.enable_parallax %}banner__parallax{% endif %}
            {% if settings.scroll_appear == 'fadein' %}fadeIn{% endif %}
            {% if disclaimer_exists %}banner__disclaimer{% endif %}
            {% if block.settings.disable_image_animation %}hero-banner-block--disable-image-animation{% endif %}
            {% if has_both_media %}hero-block--hover-video{% endif %}
            {% if has_desktop_hover %}hero-block--hover-video-desktop{% endif %}
            {% if has_mobile_hover %}hero-block--hover-video-mobile{% endif %}"
     style="background-color: {{ block.settings.section_background_color }};"
     {{ block.shopify_attributes }}>

  {%- comment -%} Background media {%- endcomment -%}
  {%- if has_images or has_videos -%}
    {% capture hero_block_background %}
      {% if has_both_media %}
        {%- comment -%} Show both image and video for hover effect - image by default, video on hover {%- endcomment -%}
        <div class="banner__media banner__media--default-image">
          {% if block.settings.enable_parallax %}<div class="banner__parallaxbg">{% endif %}
            {%- render 'image-banner-media',
                desktop_large_image: block.settings.desktop_large_image,
                desktop_image: block.settings.desktop_image,
                mobile_image: block.settings.mobile_image,
                no_lazy_load: block.settings.no_lazy_load,
                high_fetch_priority: block.settings.high_fetch_priority -%}
          {% if block.settings.enable_parallax %}</div>{% endif %}
        </div>
        <div class="banner__media banner__media--hover-video">
          {%- comment -%} Only render videos where hover is enabled {%- endcomment -%}
          {%- if has_desktop_hover -%}
            {%- if block.settings.desktop_large_video != blank -%}
              <div class="banner__media banner__media--large-screens medium-hide small-hide media">
                {{ block.settings.desktop_large_video | video_tag: autoplay: true, muted: true, loop: true }}
              </div>
            {%- endif -%}
            {%- if block.settings.desktop_video != blank -%}
              <div class="banner__media media {% if block.settings.desktop_large_video != blank %}banner__media--large-screens--hide{% endif %} small-hide">
                {{ block.settings.desktop_video | video_tag: autoplay: true, muted: true, loop: true }}
              </div>
            {%- endif -%}
          {%- endif -%}
          {%- if has_mobile_hover -%}
            {%- if block.settings.mobile_video != blank -%}
              <div class="banner__media media large-up-hide medium-hide">
                {{ block.settings.mobile_video | video_tag: autoplay: true, muted: true, loop: true }}
              </div>
            {%- endif -%}
          {%- endif -%}
        </div>
      {% elsif block.settings.use_video %}
        {%- comment -%} Use video with fallback to image where video doesn't exist {%- endcomment -%}
        <div class="banner__media media">
          {%- comment -%} Desktop: video if exists, otherwise image {%- endcomment -%}
          {%- if has_desktop_video -%}
            {%- if block.settings.desktop_large_video != blank -%}
              <div class="banner__media banner__media--large-screens medium-hide small-hide media">
                {{ block.settings.desktop_large_video | video_tag: autoplay: true, muted: true, loop: true }}
              </div>
            {%- endif -%}
            {%- if block.settings.desktop_video != blank -%}
              <div class="banner__media media {% if block.settings.desktop_large_video != blank %}banner__media--large-screens--hide{% endif %} {% if has_mobile_video %} small-hide{% endif %}">
                {{ block.settings.desktop_video | video_tag: autoplay: true, muted: true, loop: true }}
              </div>
            {%- endif -%}
          {%- elsif has_desktop_image -%}
            {%- if block.settings.desktop_large_image != blank -%}
              <div class="banner__media banner__media--large-screens medium-hide small-hide media">
                {% render 'image',
                  image: block.settings.desktop_large_image,
                  image_max_width: 2800,
                  image_desired_width: block.settings.desktop_large_image.width,
                  style: "max-width: 100%; height: 100%;",
                  do_not_lazy_load: block.settings.no_lazy_load,
                  high_fetch_priority: block.settings.high_fetch_priority,
                %}
              </div>
            {%- endif -%}
            {%- if block.settings.desktop_image != blank -%}
              <div class="banner__media media {% if block.settings.desktop_large_image != blank %}banner__media--large-screens--hide{% endif %} {% if has_mobile_image or has_mobile_video %} small-hide{% endif %}">
                {% render 'image',
                  image: block.settings.desktop_image,
                  image_max_width: 1400,
                  image_desired_width: block.settings.desktop_image.width,
                  style: "max-width: 100%; height: 100%;",
                  do_not_lazy_load: block.settings.no_lazy_load,
                  high_fetch_priority: block.settings.high_fetch_priority,
                %}
              </div>
            {%- endif -%}
          {%- endif -%}
          
          {%- comment -%} Mobile: video if exists, otherwise image {%- endcomment -%}
          {%- if has_mobile_video -%}
            <div class="banner__media media large-up-hide medium-hide">
              {{ block.settings.mobile_video | video_tag: autoplay: true, muted: true, loop: true }}
            </div>
          {%- elsif has_mobile_image -%}
            <div class="banner__media media large-up-hide medium-hide">
              {% render 'image',
                image: block.settings.mobile_image,
                image_max_width: 400,
                image_desired_width: block.settings.mobile_image.width,
                style: "max-width: 100%; height: 100%;",
                do_not_lazy_load: block.settings.no_lazy_load,
                high_fetch_priority: block.settings.high_fetch_priority,
              %}
            </div>
          {%- endif -%}
        </div>
      {% elsif has_images %}
        {% if block.settings.enable_parallax %}<div class="banner__parallaxbg">{% endif %}
          {%- render 'image-banner-media',
              desktop_large_image: block.settings.desktop_large_image,
              desktop_image: block.settings.desktop_image,
              mobile_image: block.settings.mobile_image,
              no_lazy_load: block.settings.no_lazy_load,
              high_fetch_priority: block.settings.high_fetch_priority -%}
        {% if block.settings.enable_parallax %}</div>{% endif %}
      {% endif %}
    {% endcapture %}

    {% if block.settings.background_link != blank %}
      <a class="hero-block__background-link" href="{{ block.settings.background_link }}" target="_blank" rel="noopener">
        {{ hero_block_background }}
      </a>
    {% else %}
      {{ hero_block_background }}
    {% endif %}
  {%- endif -%}

  {%- comment -%} Content container {%- endcomment -%}
  <div class="banner__content-container 
              banner__content--{{ desktop_content_position }} 
              banner__mobile--content--{{ mobile_content_position }}">
    <div class="hero__content-box"
        style="background: {{ block.settings.content_background_color | color_to_rgb | color_modify: 'alpha', background_opacity }};
        padding-top: {{ block.settings.padding_top_desktop | times: 0.1 | round: 2 }}rem;
        padding-bottom: {{ block.settings.padding_bottom_desktop | times: 0.1 | round: 2 }}rem;
        padding-left: {{ block.settings.padding_left_desktop | times: 0.1 | round: 2 }}rem;
        padding-right: {{ block.settings.padding_right_desktop | times: 0.1 | round: 2 }}rem;
        max-width: {{ block.settings.content_box_max_width | default: 100 | append:'%' }};
        margin-top:{{ block.settings.margin_top_desktop | times: 0.1 | round: 2 }}rem;
        margin-bottom:{{ block.settings.margin_bottom_desktop | times: 0.1 | round: 2 }}rem;
        margin-left:{{ block.settings.margin_left_desktop | times: 0.1 | round: 2 }}rem;
        margin-right:{{ block.settings.margin_right_desktop | times: 0.1 | round: 2 }}rem;">

      {%- comment -%} Eyebrow {%- endcomment -%}
      {%- if block.settings.eyebrow != blank -%}
        {%- assign eyebrow_style = '' -%}
        {%- if block.settings.eyebrow_color_desktop != blank -%}
          {%- assign eyebrow_style = eyebrow_style | append: 'color: ' | append: block.settings.eyebrow_color_desktop | append: ';' -%}
        {%- endif -%}
        {%- if block.settings.eyebrow_font_size != blank -%}
          {%- assign eyebrow_font_size_rem = block.settings.eyebrow_font_size | times: 0.1 | round: 2 -%}
          {%- assign eyebrow_style = eyebrow_style | append: 'font-size: ' | append: eyebrow_font_size_rem | append: 'rem;' -%}
        {%- endif -%}
        <div class="eyebrow custom-hero-block-subheading custom-hero-block-subheading--{{ block_id }} 
                    eyebrow-desktop-{{ block.settings.eyebrow_style }} 
                    eyebrow-mobile-{{ block.settings.eyebrow_style_mobile }}">
          <div style="{{ eyebrow_style }}">{{ block.settings.eyebrow }}</div>
        </div>
        {%- if block.settings.eyebrow_color_mobile != blank or block.settings.eyebrow_font_size_mobile != blank -%}
          {%- assign eyebrow_mobile_style = '' -%}
          {%- if block.settings.eyebrow_color_mobile != blank -%}
            {%- assign eyebrow_mobile_style = eyebrow_mobile_style | append: 'color: ' | append: block.settings.eyebrow_color_mobile | append: ' !important;' -%}
          {%- endif -%}
          {%- if block.settings.eyebrow_font_size_mobile != blank -%}
            {%- assign eyebrow_font_size_mobile_rem = block.settings.eyebrow_font_size_mobile | times: 0.1 | round: 2 -%}
            {%- assign eyebrow_mobile_style = eyebrow_mobile_style | append: 'font-size: ' | append: eyebrow_font_size_mobile_rem | append: 'rem !important;' -%}
          {%- endif -%}
          {%- if eyebrow_mobile_style != '' -%}
            <style>
              @media (max-width: 749px) {
                #hero-block-{{ block_id }} .custom-hero-block-subheading--{{ block_id }} > div {
                  {{ eyebrow_mobile_style }}
                }
              }
            </style>
          {%- endif -%}
        {%- endif -%}
      {%- endif -%}

      {%- comment -%} Heading {%- endcomment -%}
      {%- if block.settings.heading != blank -%}
        {%- assign heading_size = block.settings.heading_size | default: 'h1' -%}
        {%- assign heading_mobile_size = block.settings.heading_size_mobile | default: 'h1' -%}
        {%- assign heading_style = '' -%}
        {%- if block.settings.heading_color_desktop != blank and block.settings.heading_color_desktop != 'rgba(0,0,0,0)' -%}
          {%- assign heading_style = heading_style | append: 'color: ' | append: block.settings.heading_color_desktop | append: ';' -%}
        {%- endif -%}
        <{{ block.settings.heading_tag }} class="custom-hero-heading hero-heading--{{ block_id }} {{ heading_size }} heading-mobile-{{ heading_mobile_size }}" 
            {% if heading_style != '' %}style="{{ heading_style }}"{% endif %}>
          {{ block.settings.heading }}
        </{{ block.settings.heading_tag }}>
        {%- if heading_mobile_size != heading_size or block.settings.heading_color_mobile != blank -%}
          {%- assign heading_mobile_style = '' -%}
          {%- if block.settings.heading_color_mobile != blank and block.settings.heading_color_mobile != 'rgba(0,0,0,0)' -%}
            {%- assign heading_mobile_style = heading_mobile_style | append: 'color: ' | append: block.settings.heading_color_mobile | append: ' !important;' -%}
          {%- endif -%}
          <style>
            @media (max-width: 749px) {
              #hero-block-{{ block_id }} .hero-heading--{{ block_id }} {
                {% if heading_mobile_style != '' %}{{ heading_mobile_style }}{% endif %}
              }
            }
          </style>
        {%- endif -%}
      {%- endif -%}

      {%- comment -%} Body text {%- endcomment -%}
      {%- if block.settings.text != blank -%}
        {%- assign text_style = block.settings.text_style | default: 'body' -%}
        {%- assign text_mobile_style = block.settings.text_style_mobile | default: 'body' -%}
        {%- assign text_color = '' -%}
        {%- if block.settings.text_color_desktop != blank and block.settings.text_color_desktop != 'rgba(0,0,0,0)' -%}
          {%- assign text_color = text_color | append: 'color: ' | append: block.settings.text_color_desktop | append: ';' -%}
        {%- endif -%}
        <div class="custom-hero__info custom-hero__info--{{ block_id }} {{ text_style }}" 
             {% if text_color != '' %}style="{{ text_color }}"{% endif %}>
          {{ block.settings.text }}
        </div>
        {%- if text_mobile_style != text_style or block.settings.text_color_mobile != blank -%}
          {%- assign text_mobile_color = '' -%}
          {%- if block.settings.text_color_mobile != blank and block.settings.text_color_mobile != 'rgba(0,0,0,0)' -%}
            {%- assign text_mobile_color = text_mobile_color | append: 'color: ' | append: block.settings.text_color_mobile | append: ' !important;' -%}
          {%- endif -%}
          {%- if text_mobile_color != '' -%}
            <style>
              @media (max-width: 749px) {
                #hero-block-{{ block_id }} .custom-hero__info--{{ block_id }} {
                  {{ text_mobile_color }}
                }
              }
            </style>
          {%- endif -%}
        {%- endif -%}
      {%- endif -%}

      {%- comment -%} Buttons {%- endcomment -%}
      <div class="banner__buttons">
        {%- if block.settings.button_label_1 != blank -%}
          {%- assign cta1_style = '' -%}
          {%- if block.settings.button_1_background_color != blank and block.settings.button_1_background_color != 'rgba(0,0,0,0)' -%}
            {%- assign cta1_style = cta1_style | append: 'background-color: ' | append: block.settings.button_1_background_color | append: ';' -%}
          {%- endif -%}
          {%- if block.settings.button_1_text_color != blank and block.settings.button_1_text_color != 'rgba(0,0,0,0)' -%}
            {%- assign cta1_style = cta1_style | append: 'color: ' | append: block.settings.button_1_text_color | append: ';' -%}
          {%- endif -%}
          {% render 'button',
            label: block.settings.button_label_1,
            link: block.settings.button_link_1,
            ariaLabel: block.settings.button_aria_label_1,
            variation: block.settings.button_style_desktop_1,
            size: 'small',
            shape: 'round',
            style: cta1_style
          %}
        {%- endif -%}

        {%- if block.settings.button_label_2 != blank -%}
          {%- assign cta2_style = '' -%}
          {%- if block.settings.button_2_background_color != blank and block.settings.button_2_background_color != 'rgba(0,0,0,0)' -%}
            {%- assign cta2_style = cta2_style | append: 'background-color: ' | append: block.settings.button_2_background_color | append: ';' -%}
          {%- endif -%}
          {%- if block.settings.button_2_text_color != blank and block.settings.button_2_text_color != 'rgba(0,0,0,0)' -%}
            {%- assign cta2_style = cta2_style | append: 'color: ' | append: block.settings.button_2_text_color | append: ';' -%}
          {%- endif -%}
          {% if block.settings.button_link_2_video_url_desktop != blank %}
            {% render 'button',
              label: block.settings.button_label_2,
              link: '#',
              ariaLabel: block.settings.button_aria_label_2,
              variation: block.settings.button_style_desktop_2,
              size: 'small',
              showPlayIcon: true,
              shape: 'round',
              style: cta2_style
            %}
          {% else %}
            {% render 'button',
              label: block.settings.button_label_2,
              link: block.settings.button_link_2,
              ariaLabel: block.settings.button_aria_label_2,
              variation: block.settings.button_style_desktop_2,
              size: 'small',
              shape: 'round',
              style: cta2_style
            %}
          {% endif %}
        {%- endif -%}
      </div>
    </div>

    {%- comment -%} Disclaimer {%- endcomment -%}
    {%- if disclaimer_exists -%}
      <span class="banner__disclaimer-text {{ block.settings.text_style }}" data-block-id="{{ block_id }}">
        {{ block.settings.disclaimer_text }}
      </span>
    {%- endif -%}
  </div>

  {%- comment -%} Video control button - only show if use_video is enabled, play_pause_button is enabled, AND videos actually exist {%- endcomment -%}
  {%- if block.settings.use_video and block.settings.play_pause_button and has_videos -%}
    <a id="hero-block-{{ block_id }}-control-button" class="control-button" href="#">pause</a>
  {%- endif -%}
</div>

{%- comment -%} Consolidated Styles {%- endcomment -%}
{%- style -%}
  #hero-block-{{ block_id }} {
    border-radius: {{ border_radius_desktop | times: 0.1 | round: 2 }}rem;
    overflow: hidden;
  }
  #hero-block-{{ block_id }} .animated.active {
    animation-duration: {{ block.settings.animation_time }};
    animation-fill-mode: both;
    -webkit-animation-duration: {{ block.settings.animation_time }};
    -webkit-animation-fill-mode: both;
  }

  @media (max-width: 750px) {
    #hero-block-{{ block_id }} {
      border-radius: {{ border_radius_mobile | times: 0.1 | round: 2 }}rem;
    }
  }

  @media (min-width: 992px) {
    #hero-block-{{ block_id }},
    #hero-block-{{ block_id }} .banner__content {
      min-height: {{ block.settings.desktop_max_height }}px;
    }
    #hero-block-{{ block_id }} .banner__parallax {
      background-image: url("{{ block.settings.desktop_image | image_url }}");
      min-height: {{ block.settings.desktop_max_height }}px;
    }
  }

  @media (max-width: 991px) {
    #hero-block-{{ block_id }} .hero__content-box {
      padding-top: {{ block.settings.padding_top_mobile | times: 0.1 | round: 2 }}rem !important;
      padding-bottom: {{ block.settings.padding_bottom_mobile | times: 0.1 | round: 2 }}rem !important;
      padding-left: {{ block.settings.padding_left_mobile | times: 0.1 | round: 2 }}rem !important;
      padding-right: {{ block.settings.padding_right_mobile | times: 0.1 | round: 2 }}rem !important;
      max-width: {{ block.settings.content_box_max_width_mobile | default: 100 | append:'%' }} !important;
      margin-top:{{ block.settings.margin_top_mobile | times: 0.1 | round: 2 }}rem !important;
      margin-bottom:{{ block.settings.margin_bottom_mobile | times: 0.1 | round: 2 }}rem !important;
      margin-left:{{ block.settings.margin_left_mobile | times: 0.1 | round: 2 }}rem !important;
      margin-right:{{ block.settings.margin_right_mobile | times: 0.1 | round: 2 }}rem !important;
    }

    #hero-block-{{ block_id }},
    #hero-block-{{ block_id }} .banner__content {
      min-height: {{ mobile_max_height }}px;
    }
    #hero-block-{{ block_id }} .banner__parallax {
      background-image: url("{{ block.settings.mobile_image | image_url }}");
      max-height: {{ mobile_max_height }}px;
    }
    #hero-block-{{ block_id }} .banner__content {
      {%- assign mobile_pos = mobile_content_position | split: '-' -%}
      {%- assign mobile_vert = mobile_pos | first | default: 'middle' -%}
      {%- assign mobile_horz = mobile_pos | last | default: 'center' -%}
      align-items: {% case mobile_vert %}{% when 'top' %}flex-start{% when 'bottom' %}flex-end{% else %}center{% endcase %};
      justify-content: {% case mobile_horz %}{% when 'left' %}flex-start{% when 'right' %}flex-end{% else %}center{% endcase %};
    }
    {% if block.settings.hide_image_mobile %}
      #hero-block-{{ block_id }}.banner__media.media {
        display: none;
        visibility: hidden;
      }
    {% endif %}
  }

  @media (min-width: 750px) and (max-width: 989px) {
    #hero-block-{{ block_id }} .banner__parallax {
      background-image: url("{{ block.settings.desktop_image | image_url }}");
      min-height: {{ block.settings.desktop_max_height }}px;
    }
  }

  @media (min-width: 1399px) {
    #hero-block-{{ block_id }} .banner__parallax {
      background-image: url("{{ block.settings.desktop_large_image | image_url }}");
      min-height: {{ block.settings.desktop_max_height }}px;
    }
  }

  {%- if block.settings.use_video and block.settings.play_pause_button and has_videos -%}
    {%- assign btn_pos_mobile = block.settings.play_pause_position_mobile | default: block.settings.play_pause_position | default: 'top_right' -%}
    {%- assign btn_pos_desktop = block.settings.play_pause_position | default: 'top_right' -%}
    #hero-block-{{ block_id }} .control-button {
      position: absolute;
      font-size: 0;
      border: 1px solid #fff;
      border-radius: 50%;
      width: 44px;
      height: 44px;
      z-index: 2;
      background-image: url({{ 'pause.svg' | file_url }});
      background-repeat: no-repeat;
      background-position: center center;
      {% case btn_pos_mobile %}
        {% when 'top_left' %}top: 2rem; left: 2rem; right: auto; bottom: auto;
        {% when 'top_right' %}top: 2rem; right: 2rem; left: auto; bottom: auto;
        {% when 'bottom_left' %}bottom: 2rem; left: 2rem; right: auto; top: auto;
        {% when 'bottom_right' %}bottom: 2rem; right: 2rem; top: auto; left: auto;
        {% else %}top: 2rem; right: 2rem; bottom: auto; left: auto;
      {% endcase %}
    }
    #hero-block-{{ block_id }} .control-button.paused {
      background-image: url({{ 'play.svg' | file_url }});
      background-position: 56% center;
    }
    {%- comment -%} Hide button on desktop if no desktop video exists {%- endcomment -%}
    {%- unless has_desktop_video -%}
      @media (min-width: 750px) {
        #hero-block-{{ block_id }} .control-button {
          display: none;
        }
      }
    {%- endunless -%}
    {%- comment -%} Hide button on mobile if no mobile video exists {%- endcomment -%}
    {%- unless has_mobile_video -%}
      @media (max-width: 749px) {
        #hero-block-{{ block_id }} .control-button {
          display: none;
        }
      }
    {%- endunless -%}
    @media (min-width: 992px) {
      #hero-block-{{ block_id }} .control-button {
        {% case btn_pos_desktop %}
          {% when 'top_left' %}top: 6rem; left: 6rem; right: auto; bottom: auto;
          {% when 'top_right' %}top: 6rem; right: 6rem; left: auto; bottom: auto;
          {% when 'bottom_left' %}bottom: 6rem; left: 6rem; right: auto; top: auto;
          {% when 'bottom_right' %}bottom: 6rem; right: 6rem; top: auto; left: auto;
          {% else %}top: 6rem; right: 6rem; left: auto; bottom: auto;
        {% endcase %}
      }
    }
  {%- endif -%}

  {%- if block.settings.unset_min_height -%}
    @media (max-width: 749px) {
      #hero-block-{{ block_id }},
      #hero-block-{{ block_id }} .banner__content {
        min-height: unset;
      }
    }
  {%- endif -%}

  {%- if block.settings.single_block_size == 1 or block.settings.single_block_size == blank -%}
    #hero-block-{{ block_id }} > * {
      margin-bottom: 0;
    }
  {%- endif -%}

  {%- if disclaimer_exists -%}
    {%- if block.settings.text_color_desktop != 'rgba(0,0,0,0)' and block.settings.text_color_desktop != blank -%}
      #hero-block-{{ block_id }} .banner__disclaimer-text > p {
        color: {{ block.settings.text_color_desktop }};
      }
    {%- endif -%}
    @media (max-width: 749px) {
      {%- if block.settings.text_color_mobile != 'rgba(0,0,0,0)' and block.settings.text_color_mobile != blank -%}
        #hero-block-{{ block_id }} .banner__disclaimer-text > p {
          color: {{ block.settings.text_color_mobile }};
        }
      {%- endif -%}
    }
    @media (min-width: 750px) {
      #hero-block-{{ block_id }} .banner__disclaimer-text {
        {% if block.settings.alignment == "left" %}
          left: 6rem; text-align: left;
        {% elsif block.settings.alignment == "center" %}
          text-align: center; left: 50%; right: 0; transform: translateX(-50%); padding: 0 6rem; width: 100%;
        {% elsif block.settings.alignment == "right" %}
          right: 6rem; text-align: right;
        {% endif %}
      }
    }
    @media (max-width: 749px) {
      #hero-block-{{ block_id }} .banner__disclaimer-text {
        {% if block.settings.alignment_mobile == "left" %}
          left: 2rem; padding-right: 2rem; text-align: left;
        {% elsif block.settings.alignment_mobile == "center" %}
          text-align: center; left: 50%; right: 0; transform: translateX(-50%); padding: 0 2rem; width: 100%;
        {% elsif block.settings.alignment_mobile == "right" %}
          right: 2rem; padding-left: 2rem; text-align: right;
        {% endif %}
      }
    }
  {%- endif -%}

{%- endstyle -%}

{%- comment -%} Video play/pause script {%- endcomment -%}
{%- if block.settings.use_video and block.settings.play_pause_button and has_videos -%}
  <script>
    (function() {
      var btn = document.getElementById("hero-block-{{ block_id }}-control-button");
      if (!btn) return;
      var heroBlock = document.getElementById("hero-block-{{ block_id }}");
      if (!heroBlock) return;
      
      function findVisibleVideo() {
        // Get all videos (excluding hover videos)
        var allVideos = heroBlock.querySelectorAll('.banner__media:not(.banner__media--hover-video) video');
        if (allVideos.length === 0) return null;
        
        // Find the first video that is actually visible (not hidden by responsive classes)
        for (var i = 0; i < allVideos.length; i++) {
          var video = allVideos[i];
          var videoElement = video;
          var parent = videoElement.parentElement;
          
          // Check if video and its parent containers are visible
          var videoStyle = window.getComputedStyle(videoElement);
          var parentStyle = window.getComputedStyle(parent);
          
          // Check if element is visible (not display:none or visibility:hidden)
          if (videoStyle.display !== 'none' && 
              videoStyle.visibility !== 'hidden' &&
              parentStyle.display !== 'none' && 
              parentStyle.visibility !== 'hidden') {
            // Double-check by checking if it has width/height (means it's rendered)
            if (videoElement.offsetWidth > 0 && videoElement.offsetHeight > 0) {
              return videoElement;
            }
          }
        }
        
        // Fallback: return first video if none found (shouldn't happen)
        return allVideos.length > 0 ? allVideos[0] : null;
      }
      
      btn.addEventListener("click", function(e) {
        e.preventDefault();
        e.stopPropagation();
        var video = findVisibleVideo();
        if (!video) return;
        if (video.paused) {
          video.play();
          btn.innerHTML = "pause";
          btn.classList.remove('paused');
        } else {
          video.pause();
          btn.innerHTML = "play";
          btn.classList.add('paused');
        }
      });
    })();
  </script>
{%- endif -%}

{%- comment -%} Hover video play/pause script {%- endcomment -%}
{%- if has_both_media -%}
  <script>
    (function() {
      var heroBlock = document.getElementById("hero-block-{{ block_id }}");
      if (!heroBlock) return;
      
      var videos = heroBlock.querySelectorAll('.banner__media--hover-video video');
      if (videos.length === 0) return;
      
      var isHovering = false;
      
      // Pause all videos initially (they have autoplay attribute but we want to control it)
      videos.forEach(function(video) {
        video.pause();
        video.removeAttribute('autoplay');
      });
      
      function playVideos() {
        if (isHovering) return;
        isHovering = true;
        videos.forEach(function(video) {
          if (video.readyState >= 2) {
            video.play().catch(function(err) {
              console.log('Video play error:', err);
            });
          } else {
            video.addEventListener('loadeddata', function() {
              video.play().catch(function(err) {
                console.log('Video play error:', err);
              });
            }, { once: true });
          }
        });
      }
      
      function pauseVideos() {
        if (!isHovering) return;
        isHovering = false;
        videos.forEach(function(video) {
          video.pause();
          video.currentTime = 0; // Reset video to beginning
        });
      }
      
      heroBlock.addEventListener('mouseenter', playVideos);
      heroBlock.addEventListener('mouseleave', pauseVideos);
      
      // Pause videos on touch devices when user stops interacting
      heroBlock.addEventListener('touchstart', function() {
        playVideos();
      });
      
      heroBlock.addEventListener('touchend', function() {
        setTimeout(pauseVideos, 2000);
      });
    })();
  </script>
{%- endif -%}
