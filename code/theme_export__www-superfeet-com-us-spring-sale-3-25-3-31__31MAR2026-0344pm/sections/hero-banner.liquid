{% comment %}
  Reusable hero section supporting 1-up, 2-up, or 3-up layouts via multiple hero_block blocks.
{% endcomment %}
{% render 'styleguide' %}
{{ 'section-hero-banner.css' | asset_url | stylesheet_tag }}

{%- comment -%} Variables {%- endcomment -%}
{%- assign section_bg = section.settings.section_background_color | default: '#ffffff' -%}
{%- assign section_bg_mobile = section.settings.section_background_color_mobile | default: section_bg -%}
{%- assign section_max_width = section.settings.section_max_width | default: '100' | append: '%' -%}

<section id="shopify-section-{{ section.id }}"
         class="hero-banner-section custom-hero hero-banner--{{ section.blocks.size }} {{ section.settings.extra_classes }}"
         style="padding-top: {{ section.settings.padding_top | default: 0 | times: 0.1 | round: 2 }}rem;
                padding-bottom: {{ section.settings.padding_bottom | default: 0 | times: 0.1 | round: 2 }}rem;
                padding-left: {{ section.settings.padding_left_desktop | default: 0 | times: 0.1 | round: 2 }}rem;
                padding-right: {{ section.settings.padding_right_desktop | default: 0 | times: 0.1 | round: 2 }}rem;
                background-color: {{ section_bg }};
                max-width: {{ section_max_width }}">
  <div class="hero-banner__inner custom-hero-inner grid-cols-{{ section.blocks.size | at_most: 3 }}">
    {% for block in section.blocks %}
      <div class="custom-hero-banner__block">
        {% render 'hero-block', 
            block: block, 
            border_radius_desktop: section.settings.border_radius_desktop, 
            border_radius_mobile: section.settings.border_radius_mobile %}
      </div>
    {% endfor %}
  </div>
</section>

<style>
  #shopify-section-{{ section.id }} .custom-hero-inner {
    gap: {{ section.settings.block_gap_desktop | default: 0 | times: 0.1 | round: 2 }}rem;
  }

  @media (max-width: 749px) {
    .hero-banner--{{ section.blocks.size }} {
      padding-top: {{ section.settings.padding_top_mobile | default: 0 | times: 0.1 | round: 2 }}rem !important;
      padding-bottom: {{ section.settings.padding_bottom_mobile | default: 0 | times: 0.1 | round: 2 }}rem !important;
      padding-left: {{ section.settings.padding_left_mobile | default: 0 | times: 0.1 | round: 2 }}rem !important;
      padding-right: {{ section.settings.padding_right_mobile | default: 0 | times: 0.1 | round: 2 }}rem !important;
      background-color: {{ section_bg_mobile }} !important;
    }
    #shopify-section-{{ section.id }} .custom-hero-inner {
      gap: {{ section.settings.block_gap_mobile | default: 0 | times: 0.1 | round: 2 }}rem;
    }
  }
</style>

