{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Client Knowledge Pack Index Schema",
  "description": "Schema for the index.json file that maps concepts, data objects, integrations, and theme entrypoints to documentation sources",
  "type": "object",
  "required": ["theme", "data", "integrations", "concepts"],
  "properties": {
    "theme": {
      "type": "object",
      "description": "Theme architecture entrypoints",
      "additionalProperties": {
        "type": "object",
        "required": ["source"],
        "properties": {
          "source": {
            "type": "string",
            "description": "Path to documentation file"
          },
          "section": {
            "type": "string",
            "description": "Optional section anchor within the source file"
          },
          "description": {
            "type": "string",
            "description": "Brief description of the entrypoint"
          }
        }
      }
    },
    "data": {
      "type": "object",
      "description": "Data objects (metafields, metaobjects)",
      "additionalProperties": {
        "type": "object",
        "required": ["source"],
        "properties": {
          "source": {
            "type": "string",
            "description": "Path to documentation file"
          },
          "section": {
            "type": "string",
            "description": "Optional section anchor within the source file"
          },
          "namespace": {
            "type": "string",
            "description": "Metafield namespace (e.g., 'cql', 'custom')"
          },
          "type": {
            "type": "string",
            "description": "Data type (metafield, metaobject)"
          }
        }
      }
    },
    "integrations": {
      "type": "object",
      "description": "Third-party integrations",
      "additionalProperties": {
        "type": "object",
        "required": ["source"],
        "properties": {
          "source": {
            "type": "string",
            "description": "Path to documentation file"
          },
          "section": {
            "type": "string",
            "description": "Optional section anchor within the source file"
          },
          "type": {
            "type": "string",
            "description": "Integration type (theme-integrated, backend-only)"
          },
          "themeFiles": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Theme files that integrate with this app"
          }
        }
      }
    },
    "concepts": {
      "type": "object",
      "description": "Architectural concepts and patterns",
      "additionalProperties": {
        "type": "object",
        "required": ["source"],
        "properties": {
          "source": {
            "type": "string",
            "description": "Path to documentation file"
          },
          "section": {
            "type": "string",
            "description": "Optional section anchor within the source file"
          },
          "description": {
            "type": "string",
            "description": "Brief description of the concept"
          }
        }
      }
    }
  }
}